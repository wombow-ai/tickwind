# ── Tickwind config (copy to .env and fill in) ──────────────────────────
PORT=8080

# SEC EDGAR requires a User-Agent with a contact email (no API key needed).
EDGAR_USER_AGENT=Tickwind/0.1 (inverael@gmail.com)

# Comma-separated default tickers (always ingested so public pages have data;
# unioned with every user's watchlist). Matches the frontend POPULAR_TICKERS.
WATCHLIST=AAPL,NVDA,TSLA,MSFT,AMZN,GOOGL,META,AMD,NFLX,AVGO

# Storage backend: memory | postgres
# v1 default "memory" needs no DB — runs anywhere with `go run`.
STORE_BACKEND=memory

# Split storage (optional, postgres only): keep the collected/scraped corpus
# (securities, filings, quotes, news, social) on a DURABLE, backed-up DB, and the
# disposable per-user data (watchlist, clips) on the local Postgres. Set
# MARKET_DATABASE_URL to your managed DB (e.g. a Supabase session-pooler URL) to
# turn this on; docker-compose already points USER_DATABASE_URL at the local pg.
# Leave empty to keep everything in one DB (DATABASE_URL).
# MARKET_DATABASE_URL=postgresql://postgres.<ref>:<password>@<pooler-host>:5432/postgres

# How often the ingest scheduler refreshes each source.
INGEST_EVERY=15m

# ── Wired in as we add each source (all FREE; obtain when ready) ─────────
# Prices (US, all sessions incl. overnight). Use an UNFUNDED/paper account → data only.
# Empty keys disable price polling; everything else still runs.
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_FEED=iex          # iex (free) | sip (paid) | overnight
# PRICE_POLL_EVERY=10s
# Backup US real-time + company news
# FINNHUB_TOKEN=
# Social (Reddit "script" app)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# Optional LLM enrichment (per-stock summaries). OpenAI-compatible endpoint;
# empty LLM_API_KEY = disabled (the /summary endpoint returns 503).
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Supabase auth. SUPABASE_URL verifies modern ES256 tokens via the project's
# JWKS — REQUIRED, because Supabase now signs user tokens with asymmetric keys.
# SUPABASE_JWT_SECRET (legacy HS256, Settings → API → JWT secret) is optional
# fallback. With neither set, per-user endpoints return 401.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_JWT_SECRET=

# ── Server deploy (docker-compose on the Oracle Always-Free VM) ─────────
# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > create > copy token).
# This is the ONLY inbound path; no ports are opened on the VM.
# TUNNEL_TOKEN=
# Postgres password (change from the default before deploying).
# POSTGRES_PASSWORD=change-me
# DATABASE_URL / REDIS_URL are set by docker-compose automatically.

# ── Frontend (Cloudflare Pages) ─────────────────────────────────────────
# The web/ app reads this at build time to reach the API.
# NEXT_PUBLIC_API_BASE=https://api.tickwind.com
