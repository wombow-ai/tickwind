# ── Tickwind config (copy to .env and fill in) ──────────────────────────
PORT=8080

# SEC EDGAR requires a User-Agent with a contact email (no API key needed).
EDGAR_USER_AGENT=Tickwind/0.1 (inverael@gmail.com)

# Comma-separated tickers. v1 is US-first (EDGAR). HK/KR added later.
WATCHLIST=AAPL,NVDA,TSLA

# Storage backend: memory | postgres
# v1 default "memory" needs no DB — runs anywhere with `go run`.
STORE_BACKEND=memory

# How often the ingest scheduler refreshes each source.
INGEST_EVERY=15m

# ── Wired in as we add each source (all FREE; obtain when ready) ─────────
# Prices (US, all sessions incl. overnight). Use an UNFUNDED/paper account → data only.
# Empty keys disable price polling; everything else still runs.
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_FEED=iex          # iex (free) | sip (paid) | overnight
# PRICE_POLL_EVERY=10s
# Backup US real-time + company news
# FINNHUB_TOKEN=
# Social (Reddit "script" app)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# ── Server deploy (docker-compose on the Oracle Always-Free VM) ─────────
# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > create > copy token).
# This is the ONLY inbound path; no ports are opened on the VM.
# TUNNEL_TOKEN=
# Postgres password (change from the default before deploying).
# POSTGRES_PASSWORD=change-me
# DATABASE_URL / REDIS_URL are set by docker-compose automatically.

# ── Frontend (Cloudflare Pages) ─────────────────────────────────────────
# The web/ app reads this at build time to reach the API.
# NEXT_PUBLIC_API_BASE=https://api.tickwind.com
